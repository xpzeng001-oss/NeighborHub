.page { min-height: 100vh; background: #FEFCFA; }

.score-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 50rpx;
  background: #1A1A1A;
  color: #fff;
}
.score-num { font-size: 96rpx; font-weight: 700; line-height: 1; }
.score-label { font-size: 26rpx; color: #9A9A9A; margin-top: 8rpx; }
.section {
  margin-top: 20rpx;
  background: #fff;
  padding: 28rpx 30rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2C;
  margin-bottom: 24rpx;
}

.rule-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E3D5BF;
}
.rule-item:last-child { border-bottom: none; }
.rule-left { display: flex; flex-direction: column; gap: 6rpx; }
.rule-action { font-size: 28rpx; color: #2C2C2C; }
.rule-desc { font-size: 22rpx; color: #9A9A9A; }
.rule-point { font-size: 30rpx; font-weight: 600; }
.rule-point.plus { color: #C67A52; }

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F0E8DC;
}
.log-item:last-child { border-bottom: none; }
.log-left { display: flex; flex-direction: column; gap: 4rpx; }
.log-label { font-size: 28rpx; color: #2C2C2C; }
.log-time { font-size: 22rpx; color: #9A9A9A; }
.log-coins { font-size: 30rpx; font-weight: 600; color: #C67A52; }

.load-more {
  text-align: center;
  padding: 20rpx 0;
}
.load-more text { font-size: 24rpx; color: #9A9A9A; }

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
}
.empty-tip text { font-size: 24rpx; color: #9A9A9A; }
