<!--pages/dashboard/dashboard.wxml-->
<view class="page">
  <!-- 时间筛选 -->
  <view class="filter-bar">
    <view class="filter-item {{period === 'all' ? 'active' : ''}}" bindtap="switchPeriod" data-period="all">总量</view>
    <view class="filter-item {{period === 'today' ? 'active' : ''}}" bindtap="switchPeriod" data-period="today">今日</view>
    <view class="filter-item {{period === 'week' ? 'active' : ''}}" bindtap="switchPeriod" data-period="week">本周</view>
    <view class="filter-item {{period === 'month' ? 'active' : ''}}" bindtap="switchPeriod" data-period="month">本月</view>
  </view>

  <view class="dashboard" wx:if="{{dashboard}}">
    <!-- 概览卡片 -->
    <view class="dash-card">
      <view class="dash-overview">
        <view class="dash-stat">
          <text class="dash-stat-value" style="color:#C67A52;">{{dashboard.overview.userCount}}</text>
          <text class="dash-stat-label">{{periodLabel}}用户</text>
        </view>
        <view class="dash-stat">
          <text class="dash-stat-value" style="color:#4A90D9;">{{dashboard.overview.contentCount}}</text>
          <text class="dash-stat-label">{{periodLabel}}内容</text>
        </view>
        <view class="dash-stat">
          <text class="dash-stat-value" style="color:#E8883C;">{{dashboard.overview.pendingReports}}</text>
          <text class="dash-stat-label">待处理举报</text>
        </view>
        <view class="dash-stat">
          <text class="dash-stat-value" style="color:#D94A4A;">{{dashboard.overview.bannedUsers}}</text>
          <text class="dash-stat-label">封禁用户</text>
        </view>
      </view>
    </view>

    <!-- 内容分布 -->
    <view class="dash-card">
      <text class="dash-section-title">内容分布</text>
      <view class="dash-bar-list">
        <view class="dash-bar-item" wx:for="{{contentBarList}}" wx:key="label">
          <text class="dash-bar-label">{{item.label}}</text>
          <view class="dash-bar-track">
            <view class="dash-bar-fill" style="width:{{item.percent}}%;background:{{item.color}};"></view>
          </view>
          <text class="dash-bar-count">{{item.count}}</text>
        </view>
      </view>
    </view>

    <!-- 小区住户分布 -->
    <view class="dash-card" wx:for="{{dashboard.usersByCommunity}}" wx:key="community">
      <view class="dash-community-header">
        <text class="dash-section-title" style="margin-bottom:0;">{{item.community}}</text>
        <text class="dash-community-total">{{item.totalCount}}人</text>
      </view>
      <view class="dash-bar-list" style="margin-top:16rpx;">
        <view class="dash-bar-item" wx:for="{{item.buildings}}" wx:for-item="b" wx:key="building">
          <text class="dash-bar-label">{{b.building}}</text>
          <view class="dash-bar-track">
            <view class="dash-bar-fill" style="width:{{b.percent}}%;background:#C67A52;"></view>
          </view>
          <text class="dash-bar-count">{{b.count}}人</text>
        </view>
      </view>
    </view>
    <view class="dash-card" wx:if="{{!dashboard.usersByCommunity.length}}">
      <text class="dash-empty-text">暂无小区住户数据</text>
    </view>

    <!-- 7日趋势 -->
    <view class="dash-card">
      <text class="dash-section-title">近7日趋势</text>
      <view class="dash-trend">
        <view class="dash-trend-row dash-trend-header">
          <text class="dash-trend-cell">日期</text>
          <text class="dash-trend-cell">新用户</text>
          <text class="dash-trend-cell">新内容</text>
        </view>
        <view class="dash-trend-row" wx:for="{{dashboard.recentDays}}" wx:key="date">
          <text class="dash-trend-cell">{{item.date}}</text>
          <text class="dash-trend-cell" style="color:#8B6DB0;">{{item.newUsers}}</text>
          <text class="dash-trend-cell" style="color:#4A90D9;">{{item.newContent}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{!dashboard}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
