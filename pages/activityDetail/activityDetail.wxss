/* pages/activityDetail/activityDetail.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FAF8F4;
}

/* 导航栏 */
.custom-nav-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}
.custom-nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
}
.nav-actions {
  display: flex;
  gap: 16rpx;
}
.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
}
.nav-share-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  padding: 0;
  margin: 0;
  border: none;
  line-height: 1;
}
.nav-share-btn::after {
  display: none;
}

/* 滚动区域 */
.scroll-content {
  flex: 1;
  height: 0;
}

/* 封面大图 */
.hero-section {
  position: relative;
  width: 100%;
  height: 520rpx;
}
.hero-image {
  width: 100%;
  height: 100%;
}
.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3), transparent);
}

/* 信息卡片 */
.detail-card {
  background: #fff;
  margin: -40rpx 24rpx 0;
  padding: 32rpx;
  border-radius: 20rpx;
  position: relative;
  z-index: 10;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.detail-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2C2C;
  line-height: 1.4;
  flex: 1;
}
.detail-badge {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 6rpx;
}
.detail-badge.status-open { background: #4CD964; color: #fff; }
.detail-badge.status-full { background: #E8883C; color: #fff; }
.detail-badge.status-closed, .detail-badge.status-ended { background: #999; color: #fff; }
.detail-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.detail-row:last-child {
  margin-bottom: 0;
}
.row-icon {
  width: 40rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}
.row-content {
  flex: 1;
}
.row-main {
  font-size: 28rpx;
  color: #2C2C2C;
  display: block;
}
.row-main.price {
  color: #C67A52;
  font-weight: 700;
  font-size: 32rpx;
}
.row-sub {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

/* 发起人卡片 */
.organizer-card {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.organizer-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  gap: 16rpx;
}
.organizer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #E5E2DC;
}
.organizer-info {
  flex: 1;
}
.organizer-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2C;
  display: block;
}
.organizer-label {
  font-size: 22rpx;
  color: #999;
}
.btn-chat, .btn-manage {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border: 2rpx solid #C67A52;
  border-radius: 32rpx;
  font-size: 24rpx;
  line-height: 1;
  color: #C67A52;
  flex-shrink: 0;
}

/* 详情描述 */
.desc-card {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C2C2C;
  display: block;
  margin-bottom: 16rpx;
}
.desc-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 图片 */
.images-card {
  padding: 0 24rpx;
}
.detail-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

/* 参与者 */
.participants-card {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.participants-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.participants-stack {
  display: flex;
  align-items: center;
}
.participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  background: #E5E2DC;
  flex-shrink: 0;
}
.participant-avatar.overlap {
  margin-left: -24rpx;
}
.participants-left {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 16rpx;
}
.participants-count {
  font-size: 26rpx;
  color: #666;
}
.btn-join {
  padding: 12rpx 32rpx;
  background: #2C2C2C;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  flex-shrink: 0;
}
.btn-join.joined {
  background: #E5E2DC;
  color: #666;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.bar-left {
  flex: 1;
}
.bar-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #C67A52;
  display: block;
}
.bar-free {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CD964;
  display: block;
}
.bar-count {
  font-size: 22rpx;
  color: #999;
}
.bar-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #C67A52;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.bar-btn.joined {
  background: #E5E2DC;
  color: #666;
}
.bar-btn.disabled {
  background: #ccc;
  color: #fff;
}

/* 报名弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}
.modal-box {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  z-index: 201;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C2C2C;
  text-align: center;
  display: block;
  margin-bottom: 32rpx;
}
.modal-field {
  margin-bottom: 24rpx;
}
.modal-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}
.modal-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #E5E2DC;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
.modal-btn.cancel {
  background: #F5F3EF;
  color: #666;
}
.modal-btn.confirm {
  background: #2C2C2C;
  color: #fff;
}

/* 删除 */
.delete-section {
  position: fixed;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  text-align: center;
}
.delete-btn {
  font-size: 26rpx;
  color: #E8636F;
  text-decoration: underline;
}

/* 联系方式按钮 */
.btn-chat {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: transparent;
  color: #2C2C2C;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-chat::after { border: none; }
.btn-wechat {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #07C160;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-wechat::after { border: none; }
.btn-phone {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #3B82F6;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-phone::after { border: none; }
