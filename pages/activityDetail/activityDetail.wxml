<!--pages/activityDetail/activityDetail.wxml-->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav-wrap">
    <view style="height: {{statusBarHeight}}px;"></view>
    <view class="custom-nav-bar">
      <view class="nav-back" bindtap="goBack">
        <icon name="arrow-left" size="36" color="#fff"></icon>
      </view>
      <view class="nav-actions">
        <view class="nav-btn" bindtap="onShare">
          <icon name="share-2" size="32" color="#fff"></icon>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll-content" wx:if="{{detail}}">
    <!-- 封面大图 -->
    <view class="hero-section">
      <image class="hero-image" src="{{detail.coverImage || (detail.images[0] || '/images/avatar-placeholder.png')}}" mode="aspectFill"></image>
      <view class="hero-overlay"></view>
      <view class="hero-badge status-{{detail.status}}">
        {{detail.status === 'open' ? '报名中' : detail.status === 'full' ? '已满员' : '已结束'}}
      </view>
    </view>

    <!-- 活动信息 -->
    <view class="detail-card">
      <text class="detail-title">{{detail.title}}</text>

      <!-- 时间 -->
      <view class="detail-row" wx:if="{{detail.startTime}}">
        <view class="row-icon">
          <icon name="clock" size="32" color="#C67A52"></icon>
        </view>
        <view class="row-content">
          <text class="row-main">{{detail.startTimeFormatted}}</text>
          <text class="row-sub" wx:if="{{detail.endTime}}">至 {{detail.endTimeFormatted}}</text>
        </view>
      </view>

      <!-- 地点 -->
      <view class="detail-row" wx:if="{{detail.location}}">
        <view class="row-icon">
          <icon name="map-pin" size="32" color="#C67A52"></icon>
        </view>
        <view class="row-content">
          <text class="row-main">{{detail.location}}</text>
        </view>
      </view>

      <!-- 费用 -->
      <view class="detail-row">
        <view class="row-icon">
          <icon name="tag" size="32" color="#C67A52"></icon>
        </view>
        <view class="row-content">
          <text class="row-main price">{{detail.price > 0 ? '¥' + detail.price : '免费'}}</text>
          <text class="row-sub" wx:if="{{detail.maxParticipants > 0}}">限{{detail.maxParticipants}}人</text>
        </view>
      </view>
    </view>

    <!-- 发起人 -->
    <view class="organizer-card">
      <image class="organizer-avatar" src="{{detail.userAvatar || '/images/avatar-placeholder.png'}}" mode="aspectFill"></image>
      <view class="organizer-info">
        <text class="organizer-name">{{detail.userName}}</text>
        <text class="organizer-label">活动发起人</text>
      </view>
      <view class="btn-chat" bindtap="onChat" wx:if="{{!detail.isOrganizer}}">
        <icon name="message-circle" size="28" color="#C67A52"></icon>
        <text>私信</text>
      </view>
    </view>

    <!-- 活动详情 -->
    <view class="desc-card" wx:if="{{detail.description}}">
      <text class="section-title">活动详情</text>
      <text class="desc-content">{{detail.description}}</text>
    </view>

    <!-- 图片 -->
    <view class="images-card" wx:if="{{detail.images.length > 0}}">
      <image wx:for="{{detail.images}}" wx:key="*this" src="{{item}}" mode="widthFix"
             class="detail-image" bindtap="previewImage" data-src="{{item}}"></image>
    </view>

    <!-- 参与者 -->
    <view class="participants-card" wx:if="{{detail.currentParticipants > 0}}">
      <view class="participants-row">
        <view class="participants-stack">
          <image class="participant-avatar {{index > 0 ? 'overlap' : ''}}" wx:for="{{detail.participantAvatars}}" wx:key="index"
                 wx:if="{{index < 8}}" src="{{item}}" mode="aspectFill"></image>
        </view>
        <text class="participants-count">{{detail.currentParticipants}}人想参加</text>
      </view>
    </view>

    <view style="height: 200rpx;"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-bottom" wx:if="{{detail}}">
    <view class="bar-left">
      <text class="bar-price" wx:if="{{detail.price > 0}}">¥{{detail.price}}</text>
      <text class="bar-free" wx:else>免费</text>
      <text class="bar-count">{{detail.currentParticipants || 0}}人已报名</text>
    </view>
    <view class="bar-btn {{detail.isJoined ? 'joined' : ''}} {{!detail.isJoined && detail.status !== 'open' ? 'disabled' : ''}}"
          bindtap="onJoin">
      {{detail.isOrganizer ? '管理活动' : detail.isJoined ? '取消报名' : detail.status === 'open' ? '立即报名' : '报名已截止'}}
    </view>
  </view>

  <!-- 删除（发起人） -->
  <view class="delete-section" wx:if="{{detail && detail.isOrganizer}}">
    <text class="delete-btn" bindtap="onDelete">删除活动</text>
  </view>

  <!-- 报名弹窗 -->
  <view class="modal-mask" wx:if="{{showJoinModal}}" bindtap="closeJoinModal"></view>
  <view class="modal-box" wx:if="{{showJoinModal}}">
    <text class="modal-title">填写报名信息</text>
    <view class="modal-field">
      <text class="modal-label">姓名 <text style="color:#E8636F;">*</text></text>
      <input class="modal-input" placeholder="请输入姓名" value="{{joinForm.name}}" bindinput="onJoinInput" data-field="name"/>
    </view>
    <view class="modal-field">
      <text class="modal-label">手机号 <text style="color:#E8636F;">*</text></text>
      <input class="modal-input" type="number" placeholder="请输入手机号" maxlength="11" value="{{joinForm.phone}}" bindinput="onJoinInput" data-field="phone"/>
    </view>
    <view class="modal-field">
      <text class="modal-label">身份证号 <text style="color:#999;font-size:22rpx;">(选填)</text></text>
      <input class="modal-input" placeholder="请输入身份证号" maxlength="18" value="{{joinForm.idCard}}" bindinput="onJoinInput" data-field="idCard"/>
    </view>
    <view class="modal-btns">
      <view class="modal-btn cancel" bindtap="closeJoinModal">取消</view>
      <view class="modal-btn confirm" bindtap="submitJoin">确认报名</view>
    </view>
  </view>
</view>
