<!--pages/forumDetail/forumDetail.wxml-->
<view class="page">
  <scroll-view scroll-y class="scroll-content">
    <view class="post-detail">
      <!-- 头部 -->
      <view class="post-header" bindtap="goUserProfile">
        <image class="post-avatar" src="{{post.userAvatar || '/images/avatar-placeholder.png'}}" mode="aspectFill"></image>
        <view class="post-user">
          <text class="post-username">{{post.userName}}</text>
          <text class="post-time">{{post.timeAgo}}</text>
        </view>
      </view>

      <text class="post-title">{{post.title}}</text>
      <text class="post-content">{{post.content}}</text>

      <!-- 图片 -->
      <view class="post-images" wx:if="{{post.images && post.images.length > 0}}">
        <image wx:for="{{post.images}}" wx:key="index" src="{{item}}" mode="widthFix" class="post-img"></image>
      </view>

      <!-- 互动数据 -->
      <view class="post-stats">
        <view class="stat" bindtap="onLike">
          <icon name="thumbs-up" size="28" color="{{isLiked ? '#C67A52' : '#AAAAAA'}}" filled="{{isLiked}}"></icon>
          <text>{{post.likeCount}}</text>
        </view>
        <view class="stat">
          <icon name="message-circle" size="28" color="#AAAAAA"></icon>
          <text>{{post.commentCount}}</text>
        </view>
      </view>
    </view>

    <!-- 评论区 -->
    <view class="comment-section">
      <view class="section-header">
        <text class="section-title">评论 ({{comments.length}})</text>
      </view>
      <!-- 评论输入 -->
      <view class="comment-input-row">
        <image class="comment-input-avatar" src="{{myAvatar || '/images/avatar-placeholder.png'}}" mode="aspectFill"></image>
        <view class="comment-input-wrap">
          <input class="comment-input" placeholder="我有话要说..." bindinput="onCommentInput" value="{{commentText}}" confirm-type="send" bindconfirm="onSend"/>
          <view class="comment-send-btn" wx:if="{{commentText}}" bindtap="onSend">
            <icon name="send" size="28" color="#C67A52"></icon>
          </view>
        </view>
      </view>
      <!-- 评论列表 -->
      <view class="comment-item" wx:for="{{comments}}" wx:key="id">
        <image class="comment-avatar" src="{{item.userAvatar || '/images/avatar-placeholder.png'}}" mode="aspectFill"></image>
        <view class="comment-body">
          <view class="comment-meta">
            <text class="comment-name">{{item.userName}}</text>
            <text class="comment-time">· {{item.time}}</text>
          </view>
          <text class="comment-text">{{item.content}}</text>
        </view>
        <view class="comment-like">
          <icon name="thumbs-up" size="28" color="#CCCCCC"></icon>
        </view>
      </view>
      <view class="empty-comment" wx:if="{{comments.length === 0}}">
        <text class="text-secondary">暂无评论，说两句吧~</text>
      </view>
    </view>
    <view style="height: 200rpx;"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-bottom" wx:if="{{post}}">
    <button class="btn-chat" bindtap="onChat">
      <icon name="message-circle" size="32" color="#1A1A1A" filled></icon>
      <text>私信</text>
    </button>
    <button class="btn-wechat" wx:if="{{post.contactWechat}}" bindtap="onCopyWechat">
      <icon name="wechat-logo" size="32" color="#07C160" filled></icon>
      <text>微信咨询</text>
    </button>
    <button class="btn-phone" wx:if="{{post.contactPhone}}" bindtap="onCallPhone">
      <icon name="phone" size="32" color="#3B82F6" filled></icon>
      <text>电话联系</text>
    </button>
  </view>
</view>
