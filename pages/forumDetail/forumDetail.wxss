/* pages/forumDetail/forumDetail.wxss */
.page { height: 100vh; display: flex; flex-direction: column; background: #FEFCFA; }
.scroll-content { flex: 1; height: 0; }

/* 帖子主体 */
.post-detail {
  background: #fff;
  padding: 32rpx;
}
.post-header { display: flex; align-items: center; margin-bottom: 24rpx; }
.post-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 16rpx; background: #FEFCFA; }
.post-user { flex: 1; }
.post-username { font-size: 30rpx; font-weight: 600; color: #2C2C2C; display: block; }
.post-time { font-size: 22rpx; color: #9A9A9A; }
.post-title { font-size: 36rpx; font-weight: 700; color: #2C2C2C; display: block; margin-bottom: 20rpx; line-height: 1.5; }
.post-content { font-size: 28rpx; color: #666; line-height: 1.8; display: block; }
.post-images { margin-top: 20rpx; }
.post-img { width: 100%; border-radius: 16rpx; margin-bottom: 12rpx; }
.post-stats {
  display: flex;
  gap: 40rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0EDE8;
}
.stat { display: inline-flex; align-items: center; gap: 6rpx; font-size: 26rpx; color: #9A9A9A; }

/* 评论区 */
.comment-section {
  background: #fff;
  padding: 32rpx;
  border-top: 16rpx solid #F5F3F0;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.section-title { font-size: 34rpx; font-weight: 700; color: #2C2C2C; }

/* 评论输入行 */
.comment-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #F0EDE8;
}
.comment-input-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #F0EDE8;
}
.comment-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 76rpx;
  background: #F5F3F0;
  border-radius: 38rpx;
  padding: 0 24rpx;
}
.comment-input {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
  background: transparent;
}
.comment-send-btn {
  flex-shrink: 0;
  padding-left: 16rpx;
}

/* 评论列表 */
.comment-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
}
.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #F0EDE8;
  flex-shrink: 0;
}
.comment-body { flex: 1; min-width: 0; }
.comment-meta {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.comment-name { font-size: 28rpx; color: #2C2C2C; font-weight: 600; }
.comment-time { font-size: 24rpx; color: #BBBBBB; }
.comment-text { font-size: 30rpx; color: #333; line-height: 1.7; display: block; }
.comment-like {
  flex-shrink: 0;
  padding: 8rpx 0 0 16rpx;
}
.empty-comment { text-align: center; padding: 60rpx 0; font-size: 28rpx; color: #BBBBBB; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.btn-chat {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: transparent;
  color: #2C2C2C;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-chat::after { border: none; }
.btn-wechat {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #07C160;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-wechat::after { border: none; }
.btn-phone {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #3B82F6;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-phone::after { border: none; }
