<!--pages/mine/mine.wxml-->
<view class="page">
  <scroll-view scroll-y class="scroll-content">
    <!-- 用户信息卡片 -->
    <view class="profile-card">
      <view class="profile-content" wx:if="{{userInfo}}">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-placeholder.png'}}" mode="aspectFill" bindtap="goSettings"></image>
        <view class="user-info" bindtap="goSettings">
          <text class="nickname">{{userInfo.nickName}}</text>
          <view class="user-meta">
            <view style="display:inline-flex;align-items:center;gap:4rpx;">
              <icon name="map-pin" size="24" color="#888"></icon>
              <text class="building" wx:if="{{userInfo.building}}">{{userInfo.building}}</text>
              <text class="building" wx:else>未认证楼栋</text>
            </view>
          </view>
        </view>
        <view class="credit-badge" bindtap="goCredit">
          <text class="credit-label">邻里币</text>
          <text class="credit-score">{{userInfo.coins || 0}}</text>
        </view>
      </view>
      <view class="profile-content login-prompt" wx:else>
        <image class="avatar avatar-default" src="/images/avatar-placeholder.png" mode="aspectFill"></image>
        <view class="user-info">
          <text class="nickname">点击登录</text>
          <text class="login-hint">登录后享受完整服务</text>
        </view>
        <button class="login-btn-hidden" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber"></button>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="menu-group">
      <view class="menu-title">我的交易</view>
      <view class="menu-item" bindtap="goMyPublish">
        <icon name="package" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">我的发布</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goMyFav">
        <icon name="heart" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">我的收藏</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goMyActivity">
        <icon name="compass" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">我的参与</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-title">账户设置</view>
      <picker range="{{buildings}}" bindchange="onBuildingChange">
        <view class="menu-item">
          <icon name="home" size="36" color="#333" class="menu-icon-wrap"></icon>
          <text class="menu-text">楼栋认证</text>
          <view class="menu-right">
            <text class="verify-status {{isVerified ? 'verified' : ''}}">{{isVerified ? userInfo.building : '未认证'}}</text>
            <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
          </view>
        </view>
      </picker>
      <view class="menu-item" bindtap="goCredit">
        <icon name="star" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">邻里币</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goReport">
        <icon name="alert-triangle" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">举报记录</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-title">其他</view>
      <view class="menu-item share-wrap">
        <icon name="share" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">分享给邻居</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
        <button class="share-btn-hidden" open-type="share"></button>
      </view>
      <view class="menu-item" bindtap="goFeedback">
        <icon name="lightbulb" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">意见反馈</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goAbout">
        <icon name="clipboard" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">关于我们</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <!-- 管理入口（仅管理员可见） -->
    <view class="menu-group" wx:if="{{isAdmin}}">
      <view class="menu-title">管理</view>

      <!-- 数据看板 -->
      <view class="dashboard" wx:if="{{dashboard}}">
        <!-- 概览卡片 -->
        <view class="dash-overview">
          <view class="dash-stat">
            <text class="dash-stat-value" style="color:#C67A52;">{{dashboard.overview.totalUsers}}</text>
            <text class="dash-stat-label">总用户</text>
          </view>
          <view class="dash-stat">
            <text class="dash-stat-value" style="color:#4A90D9;">{{dashboard.overview.totalContent}}</text>
            <text class="dash-stat-label">总内容</text>
          </view>
          <view class="dash-stat">
            <text class="dash-stat-value" style="color:#E8883C;">{{dashboard.overview.todayContent}}</text>
            <text class="dash-stat-label">今日动态</text>
          </view>
          <view class="dash-stat">
            <text class="dash-stat-value" style="color:#8B6DB0;">{{dashboard.overview.todayNewUsers}}</text>
            <text class="dash-stat-label">今日新增</text>
          </view>
        </view>

        <!-- 第二行概览 -->
        <view class="dash-overview dash-overview-secondary">
          <view class="dash-stat">
            <text class="dash-stat-value" style="color:#4A90D9;">{{dashboard.overview.weekNewUsers}}</text>
            <text class="dash-stat-label">本周新增</text>
          </view>
          <view class="dash-stat">
            <text class="dash-stat-value" style="color:#E8883C;">{{dashboard.overview.pendingReports}}</text>
            <text class="dash-stat-label">待处理举报</text>
          </view>
          <view class="dash-stat">
            <text class="dash-stat-value" style="color:#D94A4A;">{{dashboard.overview.bannedUsers}}</text>
            <text class="dash-stat-label">封禁用户</text>
          </view>
        </view>

        <!-- 内容分布 -->
        <view class="dash-section">
          <text class="dash-section-title">内容分布</text>
          <view class="dash-bar-list">
            <view class="dash-bar-item" wx:for="{{contentBarList}}" wx:key="label">
              <text class="dash-bar-label">{{item.label}}</text>
              <view class="dash-bar-track">
                <view class="dash-bar-fill" style="width:{{item.percent}}%;background:{{item.color}};"></view>
              </view>
              <text class="dash-bar-count">{{item.count}}</text>
            </view>
          </view>
        </view>

        <!-- 住户分布 -->
        <view class="dash-section">
          <text class="dash-section-title">住户楼栋分布</text>
          <view class="dash-building-list">
            <view class="dash-building-item" wx:for="{{dashboard.usersByBuilding}}" wx:key="building">
              <text class="dash-building-name">{{item.building}}</text>
              <view class="dash-bar-track">
                <view class="dash-bar-fill" style="width:{{item.percent}}%;background:#C67A52;"></view>
              </view>
              <text class="dash-bar-count">{{item.count}}人</text>
            </view>
          </view>
        </view>

        <!-- 7日趋势 -->
        <view class="dash-section">
          <text class="dash-section-title">近7日趋势</text>
          <view class="dash-trend">
            <view class="dash-trend-row dash-trend-header">
              <text class="dash-trend-cell">日期</text>
              <text class="dash-trend-cell">新用户</text>
              <text class="dash-trend-cell">新内容</text>
            </view>
            <view class="dash-trend-row" wx:for="{{dashboard.recentDays}}" wx:key="date">
              <text class="dash-trend-cell">{{item.date}}</text>
              <text class="dash-trend-cell" style="color:#8B6DB0;">{{item.newUsers}}</text>
              <text class="dash-trend-cell" style="color:#4A90D9;">{{item.newContent}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 管理功能入口 -->
      <view class="menu-item" bindtap="goAdmin">
        <icon name="clipboard" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">内容管理</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goFeedbackList">
        <icon name="message-circle" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">用户反馈</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <view style="height: 180rpx;"></view>
  </scroll-view>

</view>
