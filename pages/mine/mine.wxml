<!--pages/mine/mine.wxml-->
<view class="page">
  <scroll-view scroll-y class="scroll-content">
    <!-- 用户信息卡片 -->
    <view class="profile-card">
      <view class="profile-content" wx:if="{{userInfo}}">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-placeholder.png'}}" mode="aspectFill" bindtap="goSettings"></image>
        <view class="user-info" bindtap="goSettings">
          <text class="nickname">{{userInfo.nickName}}</text>
          <view class="user-meta">
            <view style="display:inline-flex;align-items:center;gap:4rpx;">
              <icon name="map-pin" size="24" color="#888"></icon>
              <text class="building" wx:if="{{userInfo.community || userInfo.building}}">{{userInfo.community || ''}}{{userInfo.building ? ' ' + userInfo.building : ''}}</text>
              <text class="building" wx:else>未认证小区楼栋</text>
            </view>
          </view>
        </view>
        <view class="credit-badge" bindtap="goCredit">
          <text class="credit-label">邻里币</text>
          <text class="credit-score">{{userInfo.coins || 0}}</text>
        </view>
      </view>
      <view class="profile-content login-prompt" wx:else>
        <image class="avatar avatar-default" src="/images/avatar-placeholder.png" mode="aspectFill"></image>
        <view class="user-info">
          <text class="nickname">点击登录</text>
          <text class="login-hint">登录后享受完整服务</text>
        </view>
        <button class="login-btn-hidden" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber"></button>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="menu-group">
      <view class="menu-title">我的交易</view>
      <view class="menu-item" bindtap="goMyPublish">
        <icon name="package" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">我的发布</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goMyFav">
        <icon name="heart" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">我的收藏</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goMyActivity">
        <icon name="compass" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">我的参与</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-title">账户设置</view>
      <picker mode="multiSelector" range="{{[communityNames, buildings]}}" value="{{verifyPickerValue}}" bindcolumnchange="onVerifyPickerChange" bindchange="onVerifyConfirm" class="menu-picker">
        <view class="menu-item">
          <icon name="home" size="36" color="#333" class="menu-icon-wrap"></icon>
          <text class="menu-text">小区楼栋认证</text>
          <view class="menu-right">
            <text class="verify-status {{isVerified ? 'verified' : ''}}">{{isVerified ? userInfo.community + ' ' + userInfo.building : '未认证'}}</text>
            <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
          </view>
        </view>
      </picker>
      <view class="menu-item" bindtap="showContactEdit">
        <icon name="phone" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">联系方式</text>
        <view class="menu-right">
          <text class="verify-status {{userInfo.phone || userInfo.wechatId ? 'verified' : ''}}">{{userInfo.phone || userInfo.wechatId ? '已设置' : '未设置'}}</text>
          <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
        </view>
      </view>
      <view class="menu-item" bindtap="goCredit">
        <icon name="star" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">邻里币</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goReport">
        <icon name="alert-triangle" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">举报记录</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-title">其他</view>
      <view class="menu-item share-wrap">
        <icon name="share" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">分享给邻居</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
        <button class="share-btn-hidden" open-type="share"></button>
      </view>
      <view class="menu-item" bindtap="goFeedback">
        <icon name="lightbulb" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">意见反馈</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goAbout">
        <icon name="clipboard" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">关于我们</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <!-- 管理入口（仅管理员可见） -->
    <view class="menu-group" wx:if="{{isAdmin}}">
      <view class="menu-title">管理</view>
      <view class="menu-item" bindtap="goDashboard">
        <icon name="flame" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">数据看板</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goAdmin">
        <icon name="clipboard" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">内容管理</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goUserManage">
        <icon name="user" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">用户管理</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
      <view class="menu-item" bindtap="goFeedbackList">
        <icon name="message-circle" size="36" color="#333" class="menu-icon-wrap"></icon>
        <text class="menu-text">用户反馈</text>
        <icon name="caret-right" size="28" color="#ccc" class="menu-arrow-icon"></icon>
      </view>
    </view>

    <view style="height: 180rpx;"></view>
  </scroll-view>


</view>

<!-- 完善信息引导弹窗（放在page外层，覆盖导航栏和TabBar） -->
<view class="guide-mask" wx:if="{{showProfileGuide}}">
  <view class="guide-modal">
    <text class="guide-title">完善个人信息</text>
    <text class="guide-desc">设置昵称并认证小区楼栋，让邻居更好地认识你</text>

    <view class="guide-field">
      <text class="guide-label">昵称</text>
      <input class="guide-input" value="{{guideNickName}}" bindinput="onGuideNicknameInput" placeholder="请输入昵称" maxlength="20" />
    </view>

    <view class="guide-field">
      <text class="guide-label">小区</text>
      <picker range="{{communityNames}}" value="{{guideCommunityIndex}}" bindchange="onGuideCommunityChange">
        <view class="guide-picker">
          <text class="{{communityNames[guideCommunityIndex] ? '' : 'guide-placeholder'}}">{{communityNames[guideCommunityIndex] || '请选择小区'}}</text>
          <icon name="caret-right" size="28" color="#ccc"></icon>
        </view>
      </picker>
    </view>

    <view class="guide-field">
      <text class="guide-label">楼栋</text>
      <picker range="{{buildings}}" value="{{guideBuildingIndex}}" bindchange="onGuideBuildingChange">
        <view class="guide-picker">
          <text>{{buildings[guideBuildingIndex]}}</text>
          <icon name="caret-right" size="28" color="#ccc"></icon>
        </view>
      </picker>
    </view>

    <view class="guide-btn {{guideSaving ? 'guide-btn-disabled' : ''}}" bindtap="onGuideSave">
      <text>{{guideSaving ? '保存中...' : '确认'}}</text>
    </view>
  </view>
</view>

<!-- 联系方式编辑弹窗 -->
<view class="guide-mask" wx:if="{{showContactEdit}}" catchtap="closeContactEdit">
  <view class="guide-modal" catchtap="preventBubble">
    <text class="guide-title">至少填写一项联系方式</text>
    <text class="guide-desc">方便其他人联系到你</text>
    <view class="guide-field">
      <text class="guide-label">手机号</text>
      <view class="guide-input-wrap">
        <input class="guide-input" type="number" maxlength="11" placeholder="输入手机号" value="{{editPhone}}" bindinput="onEditPhone"/>
      </view>
    </view>
    <view class="guide-field">
      <text class="guide-label">微信号</text>
      <view class="guide-input-wrap">
        <input class="guide-input" placeholder="输入微信号" value="{{editWechat}}" bindinput="onEditWechat"/>
      </view>
    </view>
    <view class="guide-btn {{editPhone || editWechat ? '' : 'guide-btn-disabled'}}" bindtap="onContactEditSave">
      <text>确认</text>
    </view>
  </view>
</view>
