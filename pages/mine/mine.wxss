/* pages/mine/mine.wxss */
.page { background: linear-gradient(to bottom, #F0E4D8 0%, #FAF8F4 30%); min-height: 100vh; }
.scroll-content { height: 100vh; background: linear-gradient(to bottom, #F0E4D8 0%, #FAF8F4 30%); }

.profile-card {
  position: relative;
  overflow: hidden;
}
.profile-bg {
  display: none;
}
.profile-content {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx 32rpx;
  position: relative;
}
.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  background: #E5E2DC;
}
.avatar-default { opacity: 0.6; }
.user-info {
  flex: 1;
  margin-left: 24rpx;
}
.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #2C2C2C;
  display: block;
}
.user-meta { margin-top: 8rpx; }
.building { font-size: 24rpx; color: #9A9A9A; }
.login-hint { font-size: 24rpx; color: #9A9A9A; display: block; margin-top: 6rpx; }
.login-prompt { position: relative; }
.login-btn-hidden {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  opacity: 0; z-index: 1;
}
.login-btn-hidden::after { border: none; }

.credit-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #C67A52;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(198, 122, 82, 0.3);
}
.credit-label { font-size: 20rpx; color: rgba(255,255,255,0.8); }
.credit-score { font-size: 36rpx; font-weight: 700; color: #fff; }

/* 菜单 */
.menu-group {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}
.menu-title {
  padding: 24rpx 30rpx 8rpx;
  font-size: 22rpx;
  color: #9A9A9A;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #E5E2DC;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon-wrap { margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #2C2C2C; font-weight: 500; }
.menu-arrow-icon { flex-shrink: 0; }
.menu-right { display: flex; align-items: center; gap: 8rpx; }
.verify-status { font-size: 24rpx; color: #E8883C; }
.verify-status.verified { color: #C67A52; }
/* 分享按钮 */
.share-wrap { position: relative; }
.share-btn-hidden {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}
.share-btn-hidden::after { border: none; }

/* ── 管理员数据看板 ── */
.dashboard {
  padding: 0 24rpx 20rpx;
}
.dash-overview {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0EDE8;
}
.dash-overview-secondary {
  justify-content: space-around;
}
.dash-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.dash-stat-value {
  font-size: 40rpx;
  font-weight: 700;
}
.dash-stat-label {
  font-size: 20rpx;
  color: #9A9A9A;
  margin-top: 4rpx;
}

.dash-section {
  margin-top: 24rpx;
}
.dash-section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

/* 条形图 */
.dash-bar-list, .dash-building-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.dash-bar-item, .dash-building-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.dash-bar-label, .dash-building-name {
  font-size: 24rpx;
  color: #2C2C2C;
  width: 110rpx;
  flex-shrink: 0;
}
.dash-bar-track {
  flex: 1;
  height: 16rpx;
  background: #F0EDE8;
  border-radius: 8rpx;
  overflow: hidden;
}
.dash-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  min-width: 4rpx;
  transition: width 0.3s;
}
.dash-bar-count {
  font-size: 22rpx;
  color: #666;
  width: 70rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 趋势表格 */
.dash-trend {
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #F0EDE8;
}
.dash-trend-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F0EDE8;
}
.dash-trend-row:last-child {
  border-bottom: none;
}
.dash-trend-header {
  background: #FAF8F4;
}
.dash-trend-header .dash-trend-cell {
  font-weight: 600;
  color: #666;
}
.dash-trend-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #2C2C2C;
}
