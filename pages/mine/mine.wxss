/* pages/mine/mine.wxss */
.page { background: linear-gradient(to bottom, #F0E4D8 0%, #FAF8F4 30%); min-height: 100vh; }
.scroll-content { height: 100vh; background: linear-gradient(to bottom, #F0E4D8 0%, #FAF8F4 30%); }

.profile-card {
  position: relative;
  overflow: hidden;
}
.profile-bg {
  display: none;
}
.profile-content {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx 32rpx;
  position: relative;
}
.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  background: #E5E2DC;
}
.avatar-default { opacity: 0.6; }
.user-info {
  flex: 1;
  margin-left: 24rpx;
}
.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #2C2C2C;
  display: block;
}
.user-meta { margin-top: 8rpx; }
.building { font-size: 24rpx; color: #9A9A9A; }
.login-hint { font-size: 24rpx; color: #9A9A9A; display: block; margin-top: 6rpx; }
.login-prompt { position: relative; }
.login-btn-hidden {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  opacity: 0; z-index: 1;
}
.login-btn-hidden::after { border: none; }

.credit-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #C67A52;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(198, 122, 82, 0.3);
}
.credit-label { font-size: 20rpx; color: rgba(255,255,255,0.8); }
.credit-score { font-size: 36rpx; font-weight: 700; color: #fff; }

/* 菜单 */
.menu-group {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}
.menu-title {
  padding: 24rpx 30rpx 8rpx;
  font-size: 22rpx;
  color: #9A9A9A;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #E5E2DC;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon-wrap { margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #2C2C2C; font-weight: 500; }
.menu-arrow-icon { flex-shrink: 0; }
.menu-right { display: flex; align-items: center; gap: 8rpx; }
.verify-status { font-size: 24rpx; color: #E8883C; }
.verify-status.verified { color: #C67A52; }
.credit-level { font-size: 24rpx; color: #C67A52; }

/* 分享按钮 */
.share-wrap { position: relative; }
.share-btn-hidden {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}
.share-btn-hidden::after { border: none; }

/* 完善资料弹窗 */
.profile-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex; align-items: flex-end; justify-content: center;
  z-index: 999;
}
.profile-modal {
  background: #fff; width: 100%; border-radius: 32rpx 32rpx 0 0;
  padding: 0 40rpx calc(60rpx + env(safe-area-inset-bottom) + 120rpx);
  display: flex; flex-direction: column; align-items: center;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.profile-header {
  padding: 40rpx 0 8rpx; text-align: center;
}
.profile-modal-title {
  font-size: 34rpx; font-weight: 700; color: #2C2C2C; display: block;
}
.profile-modal-desc {
  font-size: 24rpx; color: #9A9A9A; margin-top: 8rpx; display: block;
}
.profile-body {
  width: 100%; display: flex; flex-direction: column; align-items: center;
  padding: 32rpx 0;
}
.avatar-pick-btn {
  background: none; border: none; padding: 0;
  position: relative; width: 144rpx; height: 144rpx;
  margin-bottom: 32rpx;
}
.avatar-pick-btn::after { border: none; }
.avatar-pick-img {
  width: 144rpx; height: 144rpx; border-radius: 50%;
  background: #F0EDE8; border: 4rpx solid #E5E2DC;
}
.avatar-pick-badge {
  position: absolute; right: 0; bottom: 0;
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #C67A52; display: flex; align-items: center; justify-content: center;
  border: 4rpx solid #fff;
}
.profile-form {
  width: 100%; background: #FAF8F4; border-radius: 16rpx;
  overflow: hidden;
}
.profile-form-item {
  display: flex; align-items: center; padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #EDE9E3;
}
.profile-form-item:last-child { border-bottom: none; }
.profile-form-label {
  font-size: 28rpx; color: #666; width: 100rpx; flex-shrink: 0;
}
.profile-form-input {
  flex: 1; font-size: 28rpx; color: #2C2C2C; text-align: right;
}
.profile-form-picker { flex: 1; }
.picker-value {
  display: flex; align-items: center; justify-content: flex-end; gap: 4rpx;
}
.picker-value.placeholder { color: #C0C0C0; }
.input-placeholder { color: #C0C0C0; }
.profile-save-btn {
  width: 100%; height: 88rpx;
  background: linear-gradient(135deg, #D4896C, #C67A52);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 44rpx; border: none;
  margin-top: 12rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(198,122,82,0.3);
}
.profile-save-btn::after { border: none; }

