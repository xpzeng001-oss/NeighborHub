/* pages/communityApply/communityApply.wxss */
.page {
  min-height: 100vh;
  background: #FAF8F4;
  padding: 24rpx 32rpx;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C2C2C;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #E8636F;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #FEFCFA;
  border: 1rpx solid #E5E2DC;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2C2C2C;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 180rpx;
  background: #FEFCFA;
  border: 1rpx solid #E5E2DC;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #2C2C2C;
  box-sizing: border-box;
}

.tip-box {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: rgba(198, 122, 82, 0.08);
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #9A7A5A;
  line-height: 1.6;
  flex: 1;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: #C67A52;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.btn-submit text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-submit.disabled {
  opacity: 0.6;
}

/* 申请记录 */
.my-apps {
  margin-top: 20rpx;
}

.app-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.app-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2C;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.status-tag.status-pending {
  color: #C67A52;
  background: #F3E8DA;
}

.status-tag.status-approved {
  color: #4CAF50;
  background: #E8F5E9;
}

.status-tag.status-rejected {
  color: #E8636F;
  background: #FCEAEC;
}

.app-address {
  font-size: 24rpx;
  color: #9A9A9A;
  display: block;
  margin-bottom: 8rpx;
}

.app-note {
  font-size: 24rpx;
  color: #C67A52;
  display: block;
  margin-bottom: 8rpx;
}

.app-time {
  font-size: 22rpx;
  color: #BFBFBF;
}
