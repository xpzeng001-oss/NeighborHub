/* pages/pet/pet.wxss */
.page { background: #FEFCFA; min-height: 100vh; display: flex; flex-direction: column; }

/* 分类Tab */
.pet-tabs {
  display: flex;
  padding: 0 32rpx;
  gap: 8rpx;
  background: #FEFCFA;
}
.pet-tab {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #AAAAAA;
  position: relative;
}
.pet-tab.active {
  color: #1A1A1A;
  font-weight: 700;
}
.pet-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #A47764;
  border-radius: 3rpx;
}

.scroll-content { flex: 1; height: 0; }
.pet-list { padding: 16rpx 32rpx; }

.pet-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 类型标签 */
.card-type {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}
.type-need { background: rgba(232, 136, 60, 0.08); color: #E8883C; }
.type-offer { background: #F3E8DA; color: #A47764; }
.type-social { background: rgba(139, 109, 176, 0.08); color: #8B6DB0; }

/* 用户信息 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #FEFCFA;
}
.user-info { flex: 1; }
.user-name { font-size: 28rpx; font-weight: 600; color: #1A1A1A; display: block; }
.user-building { font-size: 22rpx; color: #AAAAAA; }
.time { font-size: 22rpx; color: #AAAAAA; }

/* 内容 */
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.4;
}
.card-desc {
  font-size: 26rpx;
  color: #AAAAAA;
  line-height: 1.7;
  display: block;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}
.info-text { font-size: 24rpx; color: #AAAAAA; }
.reward {
  font-size: 28rpx;
  color: #A47764;
  font-weight: 700;
}

/* 标签 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}
.pet-tag {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  background: #F3E8DA;
  color: #A47764;
}

/* 底部 */
.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E3D5BF;
  overflow: hidden;
}
.response-count { font-size: 24rpx; color: #AAAAAA; white-space: nowrap; margin-right: 16rpx; }
.card-actions { display: flex; gap: 12rpx; }

.btn-contact, .btn-respond {
  width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 16rpx;
  text-align: center;
  white-space: nowrap;
}
.btn-contact {
  background: #FEFCFA;
  color: #1A1A1A;
  border: none;
}
.btn-contact::after { border: none; }
.btn-respond {
  background: #A47764;
  color: #fff;
  border: none;
}
.btn-respond::after { border: none; }

/* 浮动按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #C59A84 0%, #A47764 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(164, 119, 100, 0.4);
}
.fab-btn:active { opacity: 0.85; }
