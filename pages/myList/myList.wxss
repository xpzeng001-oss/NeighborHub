.page { min-height: 100vh; background: #FEFCFA; padding: 16rpx 0; }

/* 分类Tab */
.sub-tabs {
  display: flex;
  background: #fff;
  padding: 0 32rpx;
  margin: 0 0 16rpx;
  gap: 8rpx;
}
.sub-tab {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #9A9A9A;
  position: relative;
}
.sub-tab.active {
  color: #2C2C2C;
  font-weight: 600;
}
.sub-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #C67A52;
  border-radius: 3rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 300rpx;
  gap: 20rpx;
}
.empty-text { font-size: 28rpx; color: #9A9A9A; }

/* 商品列表 */
.product-item {
  display: flex;
  padding: 24rpx 28rpx;
  margin: 0 32rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.product-item:active { background: #FEFCFA; }

.product-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #FEFCFA;
  margin-right: 24rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.product-title {
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}
.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.product-price { font-size: 32rpx; color: #C67A52; font-weight: 700; }
.product-free { font-size: 26rpx; color: #D49A78; font-weight: 600; }
.product-status {
  font-size: 22rpx;
  color: #C67A52;
  background: #F3E8DA;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}
.product-status.sold {
  color: #9A9A9A;
  background: #E3D5BF;
}

/* 帮忙列表 */
.help-item {
  padding: 28rpx 28rpx;
  margin: 0 32rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.help-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.help-title {
  font-size: 30rpx;
  color: #2C2C2C;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.help-tag {
  font-size: 22rpx;
  color: #9A9A9A;
  background: #FEFCFA;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.help-tag.urgent {
  color: #E8636F;
  background: rgba(232, 99, 111, 0.08);
}
.help-desc {
  font-size: 26rpx;
  color: #9A9A9A;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  line-height: 1.6;
}
.help-footer { display: flex; justify-content: flex-end; }
.help-status {
  font-size: 22rpx;
  color: #D4A04A;
  font-weight: 500;
}
.help-status.done { color: #C67A52; }

/* 通用列表项（拼单/拼车/宠物） */
.general-item {
  padding: 28rpx;
  margin: 0 32rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.general-item:active { background: #FEFCFA; }
.general-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.general-title {
  font-size: 30rpx;
  color: #2C2C2C;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.general-tag {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  font-weight: 500;
}
.tag-open { background: #F3E8DA; color: #C67A52; }
.tag-done { background: #E3D5BF; color: #9A9A9A; }
.tag-need { background: rgba(232, 136, 60, 0.1); color: #E8883C; }
.tag-social { background: rgba(139, 109, 176, 0.1); color: #8B6DB0; }
.general-desc {
  font-size: 26rpx;
  color: #9A9A9A;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
  margin-bottom: 12rpx;
}
.general-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.general-meta { font-size: 22rpx; color: #9A9A9A; }

/* 我的发布（混合列表） */
.publish-item {
  display: flex;
  flex-direction: column;
  margin: 0 32rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.publish-content {
  display: flex;
  padding: 24rpx;
  min-width: 0;
}
.publish-content:active { background: #FEFCFA; }
.publish-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  margin-right: 20rpx;
}
.publish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
  gap: 8rpx;
}
.publish-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.type-tag.type-product { color: #C67A52; background: #F3E8DA; }
.type-tag.type-post { color: #5B8CDD; background: #E3EDFA; }
.type-tag.type-help { color: #E8636F; background: #FCEAEC; }
.type-tag.type-pet { color: #E8963F; background: #FBF0E0; }
.type-tag.type-sam { color: #7B61C4; background: #EDE7F6; }
.type-tag.type-carpool { color: #4CAF50; background: #E8F5E9; }
.type-tag.type-rental { color: #E8883C; background: #FFE8D0; }
.publish-title {
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.publish-desc {
  font-size: 24rpx;
  color: #9A9A9A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.publish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.publish-price { font-size: 28rpx; color: #C67A52; font-weight: 700; }
.publish-free { font-size: 24rpx; color: #D49A78; font-weight: 600; }
.publish-time { font-size: 22rpx; color: #BDBDBD; }
.publish-actions-row {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}
.action-btn-row {
  flex: 1;
  padding: 28rpx 0;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}
.action-edit { color: #4A90D9; }
.action-edit:active { background: #E3EDFA; }
.action-off { color: #9A9A9A; }
.action-off:active { background: #f5f5f5; }
.action-on { color: #4CAF50; }
.action-on:active { background: #E8F5E9; }
.action-sold { color: #9A9A9A; }
.action-sold-btn { color: #C67A52; }
.action-sold-btn:active { background: #F3E8DA; }
.action-delete { color: #E8636F; }
.action-delete:active { background: #FCEAEC; }

.loading-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #9A9A9A;
}
