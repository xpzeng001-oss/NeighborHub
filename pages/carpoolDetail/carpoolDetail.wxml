<!--pages/carpoolDetail/carpoolDetail.wxml-->
<view class="page" wx:if="{{detail}}">
  <scroll-view scroll-y class="scroll-content">
    <!-- 发布者 + 类型标签 -->
    <view class="section user-section" bindtap="goUserProfile">
      <image class="avatar" src="{{detail.userAvatar || '/images/avatar-placeholder.png'}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{detail.userName}}</text>
        <text class="user-building">{{detail.communityName}}{{detail.building ? ' ' + detail.building : ''}}</text>
      </view>
      <view class="type-badge {{detail.type === 'offer' ? 'type-offer' : 'type-seek'}}">
        <icon name="{{detail.type === 'offer' ? 'car' : 'map-pin'}}" size="24" color="{{detail.type === 'offer' ? '#C67A52' : '#4A90D9'}}"></icon>
        <text>{{detail.type === 'offer' ? '有车带人' : '找车搭乘'}}</text>
      </view>
    </view>

    <!-- 标题 -->
    <view class="section">
      <text class="title">{{detail.title}}</text>
      <text class="desc" wx:if="{{detail.description}}">{{detail.description}}</text>
    </view>

    <!-- 路线 -->
    <view class="section route-section">
      <view class="route-row">
        <view class="route-dot start"></view>
        <text class="route-text">{{detail.from}}</text>
      </view>
      <view class="route-line"></view>
      <view class="route-row">
        <view class="route-dot end"></view>
        <text class="route-text">{{detail.to}}</text>
      </view>
    </view>

    <!-- 信息 -->
    <view class="section info-section">
      <view class="info-row" wx:if="{{detail.date}}">
        <icon name="calendar" size="28" color="#999"></icon>
        <text>{{detail.date}} {{detail.time}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.seats > 0}}">
        <icon name="user" size="28" color="#999"></icon>
        <text>{{detail.takenSeats || 0}}/{{detail.seats}} 座</text>
      </view>
      <view class="info-row" wx:if="{{detail.fee}}">
        <text class="fee">¥{{detail.fee}}/人</text>
      </view>
    </view>

    <view style="height: 200rpx;"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-bottom">
    <button class="btn-chat" bindtap="onContact">
      <icon name="message-circle" size="32" color="#1A1A1A" filled></icon>
      <text>私信</text>
    </button>
    <button class="btn-wechat" wx:if="{{detail.contactWechat}}" bindtap="onCopyWechat">
      <icon name="wechat-logo" size="32" color="#07C160" filled></icon>
      <text>微信咨询</text>
    </button>
    <button class="btn-phone" wx:if="{{detail.contactPhone}}" bindtap="onCallPhone">
      <icon name="phone" size="32" color="#3B82F6" filled></icon>
      <text>电话联系</text>
    </button>
    <view class="btn-join {{detail.status !== 'open' ? 'btn-disabled' : ''}}" bindtap="onJoin" wx:if="{{!isOwner}}">
      {{detail.status === 'open' ? (detail.type === 'offer' ? '我要搭车' : '我可以带') : '已满座'}}
    </view>
  </view>
</view>
