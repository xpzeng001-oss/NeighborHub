/* pages/forum/forum.wxss */
.page { background: #FEFCFA; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

.scroll-content { flex: 1; height: 0; }
.post-list { padding: 16rpx 24rpx; }

.post-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.top-badge {
  font-size: 22rpx;
  color: #E8636F;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.post-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 16rpx; background: #E5E2DC; }
.post-user { flex: 1; }
.post-username { font-size: 28rpx; color: #2C2C2C; font-weight: 500; display: block; }
.post-time { font-size: 22rpx; color: #9A9A9A; }

.post-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2C;
  display: block;
  margin-bottom: 12rpx;
}
.post-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.post-footer {
  display: flex;
  gap: 40rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E3D5BF;
}
.footer-item { font-size: 24rpx; color: #9A9A9A; display: inline-flex; align-items: center; gap: 6rpx; }
.top-badge { display: inline-flex; align-items: center; gap: 4rpx; }

/* 浮动按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #D49A78 0%, #C67A52 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(198, 122, 82, 0.4);
}
