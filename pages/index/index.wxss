/* pages/index/index.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(to bottom, #F0E4D8 0%, #FAF8F4 30%);
}

/* 导航栏 */
.nav-header {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}
.community-select {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}
.community-name {
  font-size: 34rpx;
  color: #2C2C2C;
  font-weight: 600;
  max-width: 240rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  letter-spacing: -0.5rpx;
}

/* 搜索栏 */
.search-header {
  padding: 16rpx 32rpx 8rpx;
}
.search-input {
  display: flex;
  align-items: center;
  height: 80rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 0 28rpx;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}
.search-placeholder {
  font-size: 28rpx;
  color: #9A9A9A;
}

.scroll-content {
  flex: 1;
  height: 0;
}

/* Banner */
.banner-img {
  display: block;
  width: calc(100% - 64rpx);
  height: 260rpx;
  margin: 20rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
}

/* 分类胶囊 */
.type-scroll {
  white-space: nowrap;
  padding: 20rpx 0;
}
.type-list {
  display: flex;
  padding: 0 32rpx;
  gap: 16rpx;
}
.type-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid #E5E2DC;
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}
.type-pill text {
  font-size: 28rpx;
  color: #6B6B6B;
  font-weight: 500;
  white-space: nowrap;
}
.type-pill.active {
  background: #C67A52;
  border-color: #C67A52;
  box-shadow: 0 8rpx 24rpx rgba(198, 122, 82, 0.25);
}
.type-pill.active text {
  color: #fff;
  font-weight: 600;
}

/* 排序Tab */
.sort-bar {
  display: flex;
  padding: 12rpx 32rpx 8rpx;
  gap: 40rpx;
}
.sort-tab {
  position: relative;
  padding: 12rpx 0;
}
.sort-tab text {
  font-size: 28rpx;
  color: #9A9A9A;
}
.sort-tab.active text {
  color: #2C2C2C;
  font-weight: 700;
}
.sort-line {
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 6rpx;
  background: #C67A52;
  border-radius: 3rpx;
}
/* 商品瀑布流 */
.product-grid {
  display: flex;
  padding: 16rpx 32rpx 0;
  gap: 16rpx;
}
.grid-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.product-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.07);
}
.card-image {
  position: relative;
  width: 100%;
}
.product-img {
  width: 100%;
  height: 340rpx;
}
.free-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: #D49A78;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.card-info {
  padding: 16rpx 20rpx 20rpx;
}
.product-title {
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 12rpx;
  gap: 10rpx;
}
.price {
  font-size: 34rpx;
  color: #C67A52;
  font-weight: 700;
}
.free-price {
  font-size: 28rpx;
  color: #D49A78;
}
.original-price {
  font-size: 22rpx;
  color: #9A9A9A;
  text-decoration: line-through;
}
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.seller-info {
  font-size: 22rpx;
  color: #9A9A9A;
}
.want-count {
  font-size: 22rpx;
  color: #9A9A9A;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9A9A9A;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}
.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  max-height: 60vh;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 600;
}
.modal-close {
  font-size: 36rpx;
  color: #9A9A9A;
  padding: 10rpx;
}
.community-list { }
.community-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}
.community-option.selected {
  background: rgba(198, 122, 82, 0.1);
  color: #C67A52;
  font-weight: 500;
}
