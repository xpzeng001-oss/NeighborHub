/* pages/activity/activity.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FAF8F4;
}

/* 导航栏 */
.custom-nav-wrap {
  background: #fff;
}
.custom-nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #2C2C2C;
}

/* Tab 栏 */
.activity-tabs {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0EDE8;
}
.activity-tab {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F3EF;
  border-radius: 32rpx;
}
.activity-tab.active {
  background: #2C2C2C;
  color: #fff;
  font-weight: 600;
}

/* 滚动区域 */
.scroll-content {
  flex: 1;
  height: 0;
}
.activity-list {
  padding: 20rpx 24rpx;
}

/* 活动卡片 */
.activity-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 卡片主体（封面 + 信息） */
.card-body {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

/* 封面图 */
.card-cover-wrap {
  position: relative;
  flex-shrink: 0;
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.card-cover {
  width: 100%;
  height: 100%;
}
.card-status-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.card-status-badge.status-open {
  background: #4CD964;
  color: #fff;
}
.card-status-badge.status-full {
  background: #E8883C;
  color: #fff;
}
.card-status-badge.status-closed,
.card-status-badge.status-ended {
  background: #999;
  color: #fff;
}

/* 右侧信息 */
.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 240rpx;
  overflow: hidden;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C2C2C;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 8rpx;
}
.info-text {
  flex: 1;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 发起人 */
.organizer-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}
.organizer-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #E5E2DC;
}
.organizer-name {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx 20rpx;
  border-top: 1rpx solid #F0EDE8;
}
.footer-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

/* 参与者头像 */
.participant-avatars {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.p-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  position: relative;
  background: #E5E2DC;
}
.participant-count {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}

/* 报名按钮 */
.footer-btn {
  flex-shrink: 0;
  padding: 14rpx 36rpx;
  background: #2C2C2C;
  color: #fff;
  border-radius: 44rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
  gap: 16rpx;
}
.empty-text {
  color: #9A9A9A;
  font-size: 28rpx;
}
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9A9A9A;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #C67A52;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(198, 122, 82, 0.4);
}
