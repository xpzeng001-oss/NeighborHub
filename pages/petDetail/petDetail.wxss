.page { height: 100vh; display: flex; flex-direction: column; background: #FEFCFA; }

/* 导航栏 */
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  position: relative;
  background: #FEFCFA;
}
.nav-back {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}
.nav-title {
  position: absolute;
  left: 0; right: 0;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #2C2C2C;
}

.scroll-content { flex: 1; height: 0; }

/* 主卡片 */
.main-card {
  margin: 16rpx 32rpx 0;
  padding: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 类型标签 */
.type-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

/* 标题 */
.detail-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2C2C;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

/* 发布者 */
.author-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #E3D5BF;
}
.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FEFCFA;
  margin-right: 16rpx;
}
.author-info { flex: 1; }
.author-name { font-size: 28rpx; font-weight: 600; color: #2C2C2C; display: block; }
.author-building { font-size: 22rpx; color: #9A9A9A; }
.publish-time { font-size: 22rpx; color: #9A9A9A; }

/* 描述 */
.detail-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 信息卡片 */
.info-card {
  margin: 16rpx 32rpx 0;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.info-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #E3D5BF;
}
.info-item:last-child { border-bottom: none; }
.info-content { flex: 1; }
.info-label { font-size: 22rpx; color: #9A9A9A; display: block; margin-bottom: 4rpx; }
.info-value { font-size: 28rpx; color: #2C2C2C; font-weight: 500; }
.reward-value { color: #C67A52; font-weight: 700; }

/* 标签 */
.tags-card {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 32rpx 0;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.pet-tag {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: #F3E8DA;
  color: #C67A52;
}

/* 参与人员 */
.members-card {
  margin: 16rpx 32rpx 0;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.members-header {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 24rpx;
}
.members-title { font-size: 30rpx; font-weight: 700; color: #2C2C2C; }
.members-count { font-size: 26rpx; color: #C67A52; font-weight: 600; }

.members-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}
.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FEFCFA;
}
.member-name { font-size: 22rpx; color: #9A9A9A; max-width: 80rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.members-empty {
  padding: 20rpx 0;
}
.members-empty text { font-size: 26rpx; color: #9A9A9A; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.btn-chat {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: transparent;
  color: #2C2C2C;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-chat::after { border: none; }

/* 报名操作 */
.join-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #E3D5BF;
}
.join-row-left { flex: 1; }
.join-hint { font-size: 22rpx; color: #9A9A9A; }
.btn-join {
  padding: 12rpx 32rpx;
  background: #2C2C2C;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  flex-shrink: 0;
}
.btn-join.joined {
  background: #E5E2DC;
  color: #666;
}

/* 联系方式按钮 */
.btn-wechat {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #07C160;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-wechat::after { border: none; }
.btn-phone {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #3B82F6;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
.btn-phone::after { border: none; }
