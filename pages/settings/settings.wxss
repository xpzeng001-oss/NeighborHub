.page { background: #FEFCFA; min-height: 100vh; }

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #eee;
  background: #E5E2DC;
}
.avatar-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.avatar-hint {
  font-size: 24rpx;
  color: #C67A52;
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  background: rgba(198, 122, 82, 0.12);
}
.avatar-hint.upload {
  color: #888;
  background: rgba(0, 0, 0, 0.06);
}

.form-section {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #E5E2DC;
}
.form-item:last-child { border-bottom: none; }
.form-label {
  font-size: 28rpx;
  color: #2C2C2C;
  width: 120rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C2C2C;
  text-align: right;
}
.form-item picker {
  flex: 1;
}
.form-item-inner {
  display: flex;
  align-items: center;
}
.form-value {
  flex: 1;
  font-size: 28rpx;
  color: #2C2C2C;
  text-align: right;
}
.form-value.placeholder {
  color: #C0C0C0;
}

.apply-link {
  padding: 20rpx 54rpx;
}
.apply-link text {
  font-size: 24rpx;
  color: #C67A52;
}

.btn-wrap {
  padding: 60rpx 24rpx;
}
.btn-save {
  background: #C67A52;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 24rpx 0;
  border: none;
}
.btn-save[disabled] {
  background: #ccc;
  color: #fff;
}
.btn-logout {
  background: #fff;
  color: #E85454;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 16rpx;
  padding: 24rpx 0;
  border: none;
}
.btn-logout::after { border: 2rpx solid #E5E2DC; border-radius: 16rpx; }
