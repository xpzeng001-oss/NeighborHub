/* pages/category/category.wxss - 广场 */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(to bottom, #F0E4D8 0%, #FAF8F4 30%);
}

.page-header {
  padding: 20rpx 36rpx 16rpx;
}
.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2C2C2C;
  letter-spacing: -1rpx;
}

/* Tab 栏 */
.tab-bar {
  white-space: nowrap;
  flex-shrink: 0;
  border-bottom: 1rpx solid #F0EDE8;
}
.tab-list {
  display: flex;
  padding: 0 20rpx;
}
.tab-item {
  flex-shrink: 0;
  padding: 20rpx 28rpx;
  font-size: 30rpx;
  color: #9A9A9A;
  position: relative;
}
.tab-item.active {
  color: #2C2C2C;
  font-weight: 700;
}
.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #C67A52;
  border-radius: 3rpx;
}

/* 信息流 */
.feed-scroll {
  flex: 1;
  height: 0;
}
.feed-list {
  padding: 12rpx 24rpx;
}

/* 卡片 */
.feed-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 卡片头部 */
.feed-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.feed-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #E5E2DC;
}
.feed-user {
  flex: 1;
}
.feed-username {
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 500;
  display: block;
}
.feed-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.feed-location {
  font-size: 22rpx;
  color: #9A9A9A;
}
.feed-time {
  font-size: 22rpx;
  color: #9A9A9A;
}

/* 类型标签 */
.feed-type-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.tag-product { background: rgba(198, 122, 82, 0.12); color: #C67A52; }
.tag-post { background: rgba(74, 144, 217, 0.12); color: #4A90D9; }
.tag-help { background: rgba(232, 136, 60, 0.12); color: #E8883C; }
.tag-rental { background: rgba(212, 160, 74, 0.12); color: #D4A04A; }
.tag-pet { background: rgba(139, 109, 176, 0.12); color: #8B6DB0; }
.tag-sam { background: rgba(74, 144, 217, 0.12); color: #4A90D9; }
.tag-carpool { background: rgba(198, 122, 82, 0.12); color: #C67A52; }
.tag-activity { background: rgba(76, 217, 100, 0.12); color: #3CB371; }

/* 标题 & 描述 */
.feed-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2C;
  display: block;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.feed-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 图片 */
.feed-images {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  position: relative;
}
.feed-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.feed-img.single {
  width: 400rpx;
  height: 300rpx;
}
.feed-img-more {
  position: absolute;
  right: 0;
  top: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 底部额外信息 */
.feed-extra {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #F0EDE8;
}
.feed-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #C67A52;
}
.feed-price.free {
  font-size: 28rpx;
  color: #D49A78;
}
.feed-stat {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #9A9A9A;
}
.feed-meta {
  font-size: 24rpx;
  color: #666;
}
.feed-status {
  font-size: 22rpx;
  color: #9A9A9A;
  margin-left: auto;
}
.urgent-tag {
  font-size: 22rpx;
  background: rgba(232, 99, 111, 0.12);
  color: #E8636F;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 活动时间地点（描述下方） */
.feed-act-info {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.feed-act-info-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #999;
}

/* 活动报名状态标签（右上角） */
.feed-status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(76, 217, 100, 0.12);
  color: #3CB371;
  font-weight: 500;
  margin-right: 10rpx;
}

/* 活动卡片底部 */
.feed-participants {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.feed-p-avatars {
  position: relative;
  height: 44rpx;
  flex-shrink: 0;
}
.feed-p-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  background: #E5E2DC;
}
.feed-p-count {
  font-size: 22rpx;
  color: #999;
}

/* 活动报名按钮 */
.feed-act-btn {
  padding: 10rpx 28rpx;
  background: #2C2C2C;
  color: #fff;
  border-radius: 36rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* 空状态 & 加载更多 */
.feed-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
  gap: 16rpx;
  color: #9A9A9A;
  font-size: 28rpx;
}
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9A9A9A;
}
