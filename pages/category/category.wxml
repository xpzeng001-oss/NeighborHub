<!--pages/category/category.wxml-->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>
  <view class="page-header">
    <text class="page-title">分类</text>
  </view>

  <!-- 分类卡片网格 -->
  <view class="cat-grid">
    <view class="cat-card" wx:for="{{categories}}" wx:key="id" bindtap="goPage" data-url="{{item.url}}">
      <view class="cat-icon" style="background: {{item.tint}};">
        <icon name="{{item.icon}}" size="40" color="{{item.color}}"></icon>
      </view>
      <text class="cat-name">{{item.name}}</text>
      <text class="cat-count">{{item.count}}条信息</text>
    </view>
  </view>

</view>
