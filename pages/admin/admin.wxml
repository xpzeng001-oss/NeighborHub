<!--pages/admin/admin.wxml-->
<view class="page">

  <!-- ========== Stats Bar (仅内容管理模式) ========== -->
  <view class="stats-bar" wx:if="{{mode === 'content'}}">
    <view class="stat-card">
      <text class="stat-num {{stats.pendingReports > 0 ? 'stat-warn' : ''}}">{{stats.pendingReports || 0}}</text>
      <text class="stat-label">待处理举报</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.todayViolations || 0}}</text>
      <text class="stat-label">今日违规</text>
    </view>
    <view class="stat-card">
      <text class="stat-num {{stats.bannedUsers > 0 ? 'stat-danger' : ''}}">{{stats.bannedUsers || 0}}</text>
      <text class="stat-label">已封禁用户</text>
    </view>
  </view>

  <!-- ========== Main Tabs ========== -->
  <view class="tabs" wx:if="{{mode === 'content'}}">
    <view class="tab {{tab === 'report' ? 'active' : ''}}" bindtap="switchTab" data-tab="report">举报处理</view>
    <view class="tab {{tab === 'content' ? 'active' : ''}}" bindtap="switchTab" data-tab="content">内容管理</view>
    <view class="tab {{tab === 'user' ? 'active' : ''}}" bindtap="switchTab" data-tab="user">用户管理</view>
    <view class="tab {{tab === 'community' ? 'active' : ''}}" bindtap="switchTab" data-tab="community">小区入驻</view>
    <view class="tab {{tab === 'manage' ? 'active' : ''}}" bindtap="switchTab" data-tab="manage">小区管理</view>
    <view class="tab {{tab === 'district' ? 'active' : ''}}" bindtap="switchTab" data-tab="district">社区管理</view>
    <view class="tab {{tab === 'wechatGroup' ? 'active' : ''}}" bindtap="switchTab" data-tab="wechatGroup">群聊管理</view>
  </view>
  <view class="tabs" wx:if="{{mode === 'user'}}">
    <view class="tab {{tab === 'user' ? 'active' : ''}}" bindtap="switchTab" data-tab="user">用户管理</view>
    <view class="tab {{tab === 'community' ? 'active' : ''}}" bindtap="switchTab" data-tab="community">小区入驻</view>
    <view class="tab {{tab === 'manage' ? 'active' : ''}}" bindtap="switchTab" data-tab="manage">小区管理</view>
    <view class="tab {{tab === 'district' ? 'active' : ''}}" bindtap="switchTab" data-tab="district">社区管理</view>
  </view>

  <!-- ========== Reports Tab ========== -->
  <scroll-view scroll-y class="list-scroll" bindscrolltolower="loadMore" wx:if="{{tab === 'report'}}">

    <!-- Report Filters -->
    <view class="filter-row">
      <view class="filter-pill {{reportFilter === 'pending' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="pending">待处理</view>
      <view class="filter-pill {{reportFilter === 'resolved' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="resolved">已处理</view>
      <view class="filter-pill {{reportFilter === 'rejected' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="rejected">已驳回</view>
      <view class="filter-pill {{reportFilter === 'all' ? 'active' : ''}}" bindtap="switchReportFilter" data-filter="all">全部</view>
    </view>

    <!-- Empty State -->
    <view class="empty" wx:if="{{!loading && reportList.length === 0}}">
      <icon name="package" size="80" color="#ddd"></icon>
      <text class="empty-text">暂无举报</text>
    </view>

    <!-- Report List -->
    <view class="report-card" wx:for="{{reportList}}" wx:key="id">
      <!-- Reporter Info -->
      <view class="report-header">
        <view class="report-user">
          <image class="avatar-sm" src="{{item.userAvatar}}" mode="aspectFill"></image>
          <text class="report-username">{{item.userName}}</text>
          <text class="report-time">{{item.timeText}}</text>
        </view>
        <view class="status-badge status-{{item.status}}" wx:if="{{item.status !== 'pending'}}">{{item.statusText}}</view>
      </view>

      <!-- Report Body -->
      <view class="report-body">
        <view class="report-reason-row">
          <text class="report-reason-label">举报原因：</text>
          <text class="report-reason-text">{{item.reason}}</text>
        </view>
        <view class="report-desc" wx:if="{{item.description}}">{{item.description}}</view>
      </view>

      <!-- Target Content -->
      <view class="report-target">
        <view class="type-badge type-{{item.targetType}}">{{item.targetTypeText}}</view>
        <text class="report-target-title">{{item.targetTitle}}</text>
      </view>

      <!-- Actions (only for pending) -->
      <view class="report-actions" wx:if="{{item.status === 'pending'}}">
        <view class="btn-action btn-danger" bindtap="handleReport" data-id="{{item.id}}" data-index="{{index}}">
          <text>处理举报</text>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}"><text>加载中...</text></view>
    <view class="loading-more" wx:if="{{!reportHasMore && reportList.length > 0}}"><text>没有更多了</text></view>
  </scroll-view>

  <!-- ========== Content Tab ========== -->
  <scroll-view scroll-y class="list-scroll" bindscrolltolower="loadMore" wx:if="{{tab === 'content'}}">

    <!-- Content Type Filters -->
    <view class="filter-row">
      <view class="filter-pill {{contentType === 'all' ? 'active' : ''}}" bindtap="switchContentType" data-type="all">全部</view>
      <view class="filter-pill {{contentType === 'product' ? 'active' : ''}}" bindtap="switchContentType" data-type="product">闲置</view>
      <view class="filter-pill {{contentType === 'post' ? 'active' : ''}}" bindtap="switchContentType" data-type="post">论坛</view>
      <view class="filter-pill {{contentType === 'pet' ? 'active' : ''}}" bindtap="switchContentType" data-type="pet">宠物</view>
      <view class="filter-pill {{contentType === 'sam' ? 'active' : ''}}" bindtap="switchContentType" data-type="sam">拼单</view>
      <view class="filter-pill {{contentType === 'carpool' ? 'active' : ''}}" bindtap="switchContentType" data-type="carpool">拼车</view>
      <view class="filter-pill {{contentType === 'help' ? 'active' : ''}}" bindtap="switchContentType" data-type="help">互助</view>
    </view>

    <!-- Content Status Filters -->
    <view class="filter-row filter-row-sub">
      <view class="filter-pill-sm {{contentStatus === 'all' ? 'active' : ''}}" bindtap="switchContentStatus" data-status="all">全部</view>
      <view class="filter-pill-sm {{contentStatus === 'active' ? 'active' : ''}}" bindtap="switchContentStatus" data-status="active">正常</view>
      <view class="filter-pill-sm {{contentStatus === 'off' ? 'active' : ''}}" bindtap="switchContentStatus" data-status="off">已下架</view>
    </view>

    <!-- Empty State -->
    <view class="empty" wx:if="{{!loading && contentList.length === 0}}">
      <icon name="package" size="80" color="#ddd"></icon>
      <text class="empty-text">暂无内容</text>
    </view>

    <!-- Content List -->
    <view class="content-card" wx:for="{{contentList}}" wx:key="id">
      <view class="content-main">
        <image class="content-thumb" wx:if="{{item.images && item.images.length > 0}}" src="{{item.images[0]}}" mode="aspectFill"></image>
        <view class="content-body">
          <view class="content-title-row">
            <view class="type-badge type-{{item.type}}">{{item.typeText}}</view>
            <text class="content-title">{{item.title}}</text>
          </view>
          <text class="content-desc">{{item.description}}</text>
          <view class="content-meta">
            <view class="content-user-info">
              <image class="avatar-xs" wx:if="{{item.userAvatar}}" src="{{item.userAvatar}}" mode="aspectFill"></image>
              <text class="content-username">{{item.userName}}</text>
              <text class="content-location" wx:if="{{item.community || item.building}}">{{item.community}}{{item.building ? ' ' + item.building : ''}}</text>
            </view>
            <text class="content-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>
      <view class="content-footer">
        <view class="top-badge-sm" wx:if="{{item.isTop}}">置顶</view>
        <view class="status-badge status-{{item.status === 'off' ? 'off' : 'active'}}">{{item.status === 'off' ? '已下架' : '正常'}}</view>
        <view class="content-actions">
          <view class="btn-action btn-warn btn-sm" wx:if="{{!item.isTop}}" bindtap="toggleTop" data-type="{{item.type}}" data-id="{{item.id}}" data-index="{{index}}">
            <text>置顶</text>
          </view>
          <view class="btn-action btn-plain btn-sm" wx:if="{{item.isTop}}" bindtap="toggleTop" data-type="{{item.type}}" data-id="{{item.id}}" data-index="{{index}}">
            <text>取消置顶</text>
          </view>
          <view class="btn-action btn-danger btn-sm" wx:if="{{item.status !== 'off'}}" bindtap="takedownContent" data-type="{{item.type}}" data-id="{{item.id}}" data-index="{{index}}">
            <text>下架</text>
          </view>
          <view class="btn-action btn-success btn-sm" wx:if="{{item.status === 'off'}}" bindtap="restoreContent" data-type="{{item.type}}" data-id="{{item.id}}" data-index="{{index}}">
            <text>恢复</text>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}"><text>加载中...</text></view>
    <view class="loading-more" wx:if="{{!contentHasMore && contentList.length > 0}}"><text>没有更多了</text></view>
  </scroll-view>

  <!-- ========== Users Tab ========== -->
  <scroll-view scroll-y class="list-scroll" bindscrolltolower="loadMore" wx:if="{{tab === 'user'}}">

    <!-- Search Bar -->
    <view class="search-bar">
      <view class="search-input-wrap">
        <icon name="search" size="32" color="#9A9A9A"></icon>
        <input class="search-input" placeholder="搜索昵称或手机号" value="{{userKeyword}}" bindinput="searchUser" />
      </view>
    </view>

    <!-- Empty State -->
    <view class="empty" wx:if="{{!loading && userList.length === 0}}">
      <icon name="package" size="80" color="#ddd"></icon>
      <text class="empty-text">暂无用户</text>
    </view>

    <!-- User List -->
    <view class="user-card" wx:for="{{userList}}" wx:key="id">
      <view class="user-main" bindtap="goUserProfile" data-user-id="{{item.id}}">
        <image class="avatar-md" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-info">
          <view class="user-name-row">
            <text class="user-name">{{item.nickName}}</text>
            <view class="ban-badge" wx:if="{{item.isBanned}}">已封禁</view>
          </view>
          <text class="user-building" wx:if="{{item.community || item.building}}">{{item.community}}{{item.building ? ' ' + item.building : ''}}</text>
          <text class="user-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
          <view class="user-stats">
            <view class="user-stat">
              <text class="user-stat-label">邻里币</text>
              <text class="user-stat-value">{{item.coins || 0}}</text>
            </view>
            <view class="user-stat">
              <text class="user-stat-label">发布数</text>
              <text class="user-stat-value">{{item.publishCount || 0}}</text>
            </view>
            <view class="user-stat">
              <text class="user-stat-label">违规次数</text>
              <text class="user-stat-value {{item.violationCount > 0 ? 'violation-count' : ''}}">{{item.violationCount || 0}}</text>
            </view>
            <view class="user-stat">
              <text class="user-stat-label">注册时间</text>
              <text class="user-stat-value">{{item.timeText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="user-actions">
        <view class="btn-action btn-danger btn-sm" wx:if="{{!item.isBanned}}" bindtap="banUser" data-id="{{item.id}}" data-index="{{index}}">
          <text>封禁</text>
        </view>
        <view class="btn-action btn-success btn-sm" wx:if="{{item.isBanned}}" bindtap="unbanUser" data-id="{{item.id}}" data-index="{{index}}">
          <text>解封</text>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}"><text>加载中...</text></view>
    <view class="loading-more" wx:if="{{!userHasMore && userList.length > 0}}"><text>没有更多了</text></view>
  </scroll-view>

  <!-- ========== Community Applications Tab ========== -->
  <scroll-view scroll-y class="list-scroll" bindscrolltolower="loadMore" wx:if="{{tab === 'community'}}">

    <!-- Filters -->
    <view class="filter-row">
      <view class="filter-pill {{communityFilter === 'pending' ? 'active' : ''}}" bindtap="switchCommunityFilter" data-filter="pending">待审核</view>
      <view class="filter-pill {{communityFilter === 'approved' ? 'active' : ''}}" bindtap="switchCommunityFilter" data-filter="approved">已通过</view>
      <view class="filter-pill {{communityFilter === 'rejected' ? 'active' : ''}}" bindtap="switchCommunityFilter" data-filter="rejected">已拒绝</view>
      <view class="filter-pill {{communityFilter === 'all' ? 'active' : ''}}" bindtap="switchCommunityFilter" data-filter="all">全部</view>
    </view>

    <!-- Empty -->
    <view class="empty" wx:if="{{!loading && communityList.length === 0}}">
      <icon name="package" size="80" color="#ddd"></icon>
      <text class="empty-text">暂无申请</text>
    </view>

    <!-- Application List -->
    <view class="report-card" wx:for="{{communityList}}" wx:key="id">
      <view class="report-header">
        <view class="report-user">
          <image class="avatar-sm" src="{{item.userAvatar}}" mode="aspectFill"></image>
          <text class="report-username">{{item.userName}}</text>
          <text class="report-time">{{item.timeText}}</text>
        </view>
        <view class="status-badge status-{{item.status}}" wx:if="{{item.status !== 'pending'}}">
          {{item.status === 'approved' ? '已通过' : '已拒绝'}}
        </view>
      </view>

      <view class="report-body">
        <view class="report-reason-row">
          <text class="report-reason-label">小区名称：</text>
          <text class="report-reason-text">{{item.name}}</text>
        </view>
        <view class="report-reason-row" wx:if="{{item.address}}">
          <text class="report-reason-label">地址：</text>
          <text class="report-reason-text">{{item.address}}</text>
        </view>
        <view class="report-desc" wx:if="{{item.reason}}">申请理由：{{item.reason}}</view>
        <view class="report-desc" wx:if="{{item.contact}}">联系方式：{{item.contact}}</view>
      </view>

      <view class="report-actions" wx:if="{{item.status === 'pending'}}">
        <view class="btn-action btn-success btn-sm" bindtap="approveCommunity" data-id="{{item.id}}" data-index="{{index}}">
          <text>通过</text>
        </view>
        <view class="btn-action btn-danger btn-sm" bindtap="rejectCommunity" data-id="{{item.id}}" data-index="{{index}}">
          <text>拒绝</text>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}"><text>加载中...</text></view>
    <view class="loading-more" wx:if="{{!communityHasMore && communityList.length > 0}}"><text>没有更多了</text></view>
  </scroll-view>

  <!-- ========== Community Management Tab ========== -->
  <scroll-view scroll-y class="list-scroll" bindscrolltolower="loadMore" wx:if="{{tab === 'manage'}}">

    <!-- Search + Add -->
    <view class="manage-toolbar">
      <view class="search-input-wrap manage-search">
        <icon name="search" size="32" color="#9A9A9A"></icon>
        <input class="search-input" placeholder="搜索小区名称" value="{{manageCommunityKeyword}}" bindinput="searchCommunity" />
      </view>
      <view class="btn-action btn-add" bindtap="addCommunity">
        <text>+ 添加</text>
      </view>
    </view>

    <!-- Empty -->
    <view class="empty" wx:if="{{!loading && manageCommunityList.length === 0}}">
      <text class="empty-text">暂无小区</text>
    </view>

    <!-- Community List -->
    <view class="community-card" wx:for="{{manageCommunityList}}" wx:key="id">
      <view class="community-main">
        <view class="community-name">{{item.name}}</view>
        <view class="community-address" wx:if="{{item.address}}">{{item.address}}</view>
        <view class="community-meta">
          <text class="community-time">{{item.timeText}}</text>
        </view>
      </view>
      <view class="community-actions">
        <view class="btn-action btn-danger btn-sm" bindtap="deleteCommunity" data-id="{{item.id}}" data-name="{{item.name}}" data-index="{{index}}">
          <text>删除</text>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}"><text>加载中...</text></view>
    <view class="loading-more" wx:if="{{!manageCommunityHasMore && manageCommunityList.length > 0}}"><text>没有更多了</text></view>
  </scroll-view>

  <!-- ========== District Management Tab ========== -->
  <scroll-view scroll-y class="list-scroll" wx:if="{{tab === 'district'}}">

    <view class="manage-toolbar">
      <text style="font-size: 28rpx; color: #9A9A9A; flex: 1;">共 {{districtList.length}} 个社区</text>
      <view class="btn-action btn-add" bindtap="addDistrict">
        <text>+ 添加社区</text>
      </view>
    </view>

    <view class="empty" wx:if="{{districtList.length === 0}}">
      <text class="empty-text">暂无社区</text>
    </view>

    <view class="district-card" wx:for="{{districtList}}" wx:key="id">
      <view class="district-header">
        <view class="district-name">{{item.name}}</view>
        <view class="btn-action btn-danger btn-sm" bindtap="deleteDistrict" data-id="{{item.id}}" data-name="{{item.name}}">
          <text>删除</text>
        </view>
      </view>
      <view class="district-communities">
        <text class="district-label">下辖小区 ({{item.communityCount || 0}})：</text>
        <view class="district-community-list">
          <text class="district-community-tag" wx:for="{{item.communities}}" wx:for-item="c" wx:key="id">{{c.name}}</text>
          <text class="district-community-empty" wx:if="{{!item.communities || item.communities.length === 0}}">暂无小区</text>
        </view>
      </view>
    </view>

    <!-- 未分配小区 -->
    <view class="manage-toolbar" style="margin-top: 20rpx;">
      <text style="font-size: 28rpx; color: #9A9A9A;">小区分配（点击分配到社区）</text>
    </view>
    <view class="community-card" wx:for="{{manageCommunityList}}" wx:key="id">
      <view class="community-main">
        <view class="community-name">{{item.name}}</view>
      </view>
      <view class="btn-action btn-add btn-sm" bindtap="assignDistrict" data-id="{{item.id}}" data-name="{{item.name}}">
        <text>分配</text>
      </view>
    </view>
  </scroll-view>

  <!-- ========== Wechat Group Management Tab ========== -->
  <scroll-view scroll-y class="list-scroll" wx:if="{{tab === 'wechatGroup'}}">

    <view class="manage-toolbar">
      <text style="font-size: 28rpx; color: #9A9A9A; flex: 1;">共 {{wechatGroupList.length}} 个群聊</text>
      <view class="btn-action btn-add" bindtap="addWechatGroup">
        <text>+ 添加群聊</text>
      </view>
    </view>

    <view class="empty" wx:if="{{wechatGroupList.length === 0}}">
      <icon name="wechat-logo" size="80" color="#ddd"></icon>
      <text class="empty-text">暂无群聊</text>
    </view>

    <view class="wg-card" wx:for="{{wechatGroupList}}" wx:key="id">
      <view class="wg-body">
        <image class="wg-qr" src="{{item.qrcode_url}}" mode="aspectFill" catchtap="previewGroupQr" data-url="{{item.qrcode_url}}"></image>
        <view class="wg-info">
          <text class="wg-name">{{item.name}}</text>
          <text class="wg-desc" wx:if="{{item.description}}">{{item.description}}</text>
          <text class="wg-meta">排序: {{item.sort_order || 0}}　状态: {{item.status === 'active' ? '启用' : '停用'}}</text>
        </view>
      </view>
      <view class="wg-actions">
        <view class="btn-action btn-warn btn-sm" bindtap="editWechatGroup" data-index="{{index}}">
          <text>编辑</text>
        </view>
        <view class="btn-action btn-danger btn-sm" bindtap="deleteWechatGroup" data-id="{{item.id}}" data-name="{{item.name}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </scroll-view>

</view>
