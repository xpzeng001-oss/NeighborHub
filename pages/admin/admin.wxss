.page { height: 100vh; display: flex; flex-direction: column; background: #FEFCFA; }

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  flex-shrink: 0;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #9A9A9A;
  font-weight: 500;
  position: relative;
}
.tab.active {
  color: #C67A52;
  font-weight: 700;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #C67A52;
  border-radius: 3rpx;
}

/* List */
.list-scroll { flex: 1; height: 0; padding: 16rpx 0; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  gap: 20rpx;
}
.empty-text { font-size: 28rpx; color: #9A9A9A; }

.item {
  display: flex;
  align-items: center;
  margin: 0 24rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.item-main {
  flex: 1;
  display: flex;
  padding: 20rpx 24rpx;
  min-width: 0;
}
.item-main:active { background: #FEFCFA; }
.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}
.item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}
.item-title {
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}
.item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.item-user { font-size: 24rpx; color: #9A9A9A; }
.item-status {
  font-size: 22rpx;
  color: #C67A52;
  background: #F3E8DA;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.item-delete {
  width: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-left: 1rpx solid #f0f0f0;
  align-self: stretch;
}
.item-delete:active { background: rgba(232,99,111,0.08); }
.delete-text {
  font-size: 24rpx;
  color: #E8636F;
  font-weight: 600;
}

.loading-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #9A9A9A;
}
