.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 110rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 普通Tab项 */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 110rpx;
  position: relative;
}

.tab-item text {
  font-size: 20rpx;
  color: #BBBBBB;
  margin-top: 4rpx;
  font-weight: 500;
}

.tab-item.active text {
  color: #C67A52;
  font-weight: 600;
}

/* 中间发布按钮 */
.tab-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 110rpx;
}

.fab-btn {
  width: 80rpx;
  height: 80rpx;
  background: #C67A52;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(198, 122, 82, 0.15);
}

.fab-btn:active {
  opacity: 0.85;
  transform: scale(0.95);
}

/* 消息未读红点 */
.msg-tab { position: relative; }
.unread-badge {
  position: absolute;
  top: 10rpx;
  right: 50%;
  margin-right: -40rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #E8636F;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 3rpx solid #fff;
}
.unread-badge text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
  margin-top: 0;
}
